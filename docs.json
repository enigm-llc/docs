        ]
      },
      {
        "tab": "Security & Trust",
        "groups": [
          {
            "group": "Security",
            "expanded": true,
            "pages": [
              "security/security-model",
              "security/privacy-principles",
              "security/privacy-model",
              "security/threat-model",
              "security/cryptography",
              "security/compliance",
              "security/transparency"
