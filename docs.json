{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Enigm",
  "colors": {
    "primary": "#000000",
    "light": "#848484",
    "dark": "#ffffff"
  },
  "favicon": {
    "light": "/images/favicon-enigm.png",
    "dark": "/images/favicon-enigm.png"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-enigm-comp.svg",
    "dark": "/images/logo-enigm-comp-white.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@enigm.ioo"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/enigm_io",
      "github": "https://github.com/enigm-llc",
      "linkedin": "https://www.linkedin.com/company/enigm-io",
      "instagram": "https://www.instagram.com/enigm.io",
      "youtube": "https://www.youtube.com/@Enigm-io"
    }
  }
}
