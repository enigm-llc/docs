{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Enigm",
  "description": "Technical documentation for Enigm privacy messaging, secure devices, private connectivity, command workflows, security, trust, and compliance.",
  "theme": "mint",
  "modeToggle": {
    "default": "dark"
  },
  "colors": {
    "primary": "#000000",
    "light": "#000000",
    "dark": "#FFFFFF"
  },
  "logo": {
    "light": "/assets/brand/logo.svg",
    "dark": "/assets/brand/logo-white.svg",
    "href": "/"
  },
  "favicon": "/assets/brand/favicon.svg",
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#000000"
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "canonical": "https://docs.enigm.io",
      "keywords": "Enigm, private messaging, secure messaging, encrypted communications, secure devices, Enigm OS, Enigm Command, Enigm Key, Enigm eSIM, private server, security documentation, privacy documentation, device trust, remote attestation, post-quantum cryptography, ISO 27001",
      "og:site_name": "Enigm",
      "og:type": "website",
      "og:url": "https://docs.enigm.io",
      "twitter:card": "summary_large_image",
      "twitter:site": "@enigm_io"
    }
  },
  "search": {
    "prompt": "Search Enigm documentation..."
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://enigm.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Enigm Command",
      "href": "https://app.enigm.io"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/enigm_io",
      "github": "https://github.com/enigm-llc",
      "linkedin": "https://www.linkedin.com/company/enigm-io/",
      "youtube": "https://www.youtube.com/@Enigm-io"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Products",
        "groups": [
          {
            "group": "Overview",
            "expanded": true,
            "pages": [
              "introduction",
              "platform/architecture"
            ]
          },
          {
            "group": "Enigm",
            "pages": [
              "app/overview",
              "app/account-model",
              "app/key-management",
              "app/secure-messaging",
              "app/secure-calls",
              "app/active-defense",
              "app/multi-device"
            ]
          },
          {
            "group": "Enigm Command",
            "pages": [
              "platform/control-panel"
            ]
          },
          {
            "group": "Enigm Server",
            "pages": [
              "platform/private-environments",
              "platform/vpn",
              "platform/proxy-network",
              "platform/tor-gateway"
            ]
          },
          {
            "group": "Enigm eSIM",
            "pages": [
              "platform/esim"
            ]
          },
          {
            "group": "Enigm Key",
            "pages": [
              "platform/enigm-key"
            ]
          },
          {
            "group": "Enigm OS",
            "pages": [
              "os/overview",
              "os/security-architecture",
              "os/trust-security-center",
              "os/setup-wizard",
              "os/launcher",
              "os/network-policy",
              "os/privacy-mode",
              "os/device-management",
              {
                "group": "OTA",
                "pages": [
                  "os/ota/overview",
                  "os/ota/security-model",
                  "os/ota/remote-attestation",
                  "os/ota/signing",
                  "os/ota/release-lifecycle",
                  "os/ota/client-verification"
                ]
