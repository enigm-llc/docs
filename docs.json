{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Enigm",
  "description": "Technical documentation for Enigm privacy messaging, secure devices, private connectivity, command workflows, security, trust, and compliance.",
  "theme": "mint",
  "modeToggle": {
    "default": "dark"
  },
  "colors": {
    "primary": "#000000",
    "light": "#000000",
    "dark": "#FFFFFF"
  },
  "logo": {
    "light": "/assets/brand/logo.svg",
    "dark": "/assets/brand/logo-white.svg",
    "href": "/"
  },
  "favicon": "/assets/brand/favicon.svg",
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#000000"
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "canonical": "https://docs.enigm.io",
      "keywords": "Enigm, private messaging, secure messaging, encrypted communications, secure devices, Enigm OS, Enigm Command, Enigm Key, Enigm eSIM, Enigm Server, payment privacy, private server, security documentation, privacy documentation, device trust, remote attestation, post-quantum cryptography, ISO 27001",
      "og:site_name": "Enigm",
      "og:type": "website",
      "og:url": "https://docs.enigm.io",
      "twitter:card": "summary_large_image",
      "twitter:site": "@enigm_io"
    }
  },
  "search": {
    "prompt": "Search Enigm documentation..."
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://enigm.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Enigm Command",
      "href": "https://app.enigm.io"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/enigm_io",
      "github": "https://github.com/enigm-llc",
      "linkedin": "https://www.linkedin.com/company/enigm-io/",
      "youtube": "https://www.youtube.com/@Enigm-io"
    }
  },
